rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── users 컬렉션 ──────────────────────────────────────────────
    match /users/{userId} {
      allow read: if true;
      // 신규 생성 시에만 필수 필드 검증, 수정은 자유롭게 허용
      allow create: if isValidUser(request.resource.data);
      allow update: if true;
      // admin 계정은 삭제 금지
      allow delete: if resource.data.role != 'admin';
    }

    // ── schedules 컬렉션 ─────────────────────────────────────────
    match /schedules/{scheduleId} {
      allow read: if true;
      allow create: if isValidSchedule(request.resource.data);
      allow update: if true;
      allow delete: if true;
    }

    // ── settings 컬렉션 (알림 설정 등) ───────────────────────────
    match /settings/{docId} {
      allow read, write: if true;
    }

    // ── 그 외 컬렉션: 거부 ────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ── 검증 함수 ────────────────────────────────────────────────
    function isValidUser(data) {
      return data.keys().hasAll(['id', 'pw', 'name', 'role'])
        && data.role in ['admin', 'driver']
        && data.id is string && data.id.size() <= 50
        && data.pw is string && data.pw.size() <= 200
        && data.name is string && data.name.size() <= 30;
    }

    function isValidSchedule(data) {
      return data.keys().hasAll(['date', 'status'])
        && data.status in ['대기', '이동중', '진행중', '완료', '청구완료']
        && data.date is string && data.date.size() == 10;
    }
  }
}
