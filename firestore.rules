rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── users 컬렉션 ──────────────────────────────────────────────
    match /users/{userId} {
      // 읽기: 허용 (로그인 시 전체 목록 조회 필요)
      allow read: if true;

      // 쓰기: 필수 필드 및 역할 유효성 검증
      allow create: if isValidUser(request.resource.data);
      allow update: if isValidUser(request.resource.data);

      // 삭제: admin 계정은 삭제 금지
      allow delete: if resource.data.role != 'admin';
    }

    // ── schedules 컬렉션 ─────────────────────────────────────────
    match /schedules/{scheduleId} {
      // 읽기: 허용
      allow read: if true;

      // 쓰기: 필수 필드 및 상태값 유효성 검증
      allow create: if isValidSchedule(request.resource.data);
      allow update: if isValidScheduleUpdate(request.resource.data);
      allow delete: if true;
    }

    // ── 그 외 컬렉션: 거부 ────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ── 검증 함수 ────────────────────────────────────────────────
    function isValidUser(data) {
      return data.keys().hasAll(['id', 'pw', 'name', 'role'])
        && data.role in ['admin', 'driver']
        && data.id is string && data.id.size() <= 50
        && data.pw is string && data.pw.size() <= 200
        && data.name is string && data.name.size() <= 30;
    }

    function isValidSchedule(data) {
      return data.keys().hasAll(['date', 'status'])
        && data.status in ['대기', '이동중', '진행중', '완료', '청구완료']
        && data.date is string && data.date.size() == 10;
    }

    function isValidScheduleUpdate(data) {
      return !data.keys().hasAll(['status'])
        || data.status in ['대기', '이동중', '진행중', '완료', '청구완료'];
    }
  }
}
